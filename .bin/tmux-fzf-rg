#!/usr/bin/env bash
# Live rg+fzf grep → open selection at line via nvr.
set -e

RG="rg --color=always --line-number --no-heading --smart-case"

: | fzf --ansi --disabled \
    --bind "start:reload:$RG {q} || true" \
    --bind "change:reload:sleep 0.1; $RG {q} || true" \
    --delimiter : \
    --preview 'bat --color=always --highlight-line {2} --style=numbers {1} 2>/dev/null' \
    --preview-window 'up,60%,border-bottom,+{2}+3/3,~3' \
    --bind 'enter:become(nvr +{2} {1})'
