#!/usr/bin/env bash
# fzf file picker → send to the session's nvim-server via nvr.
# Tab to multi-select, Enter to confirm.
set -e
sels=$(fd --type f --hidden --exclude .git 2>/dev/null | fzf --multi) || exit 0
[ -z "$sels" ] && exit 0
files=()
while IFS= read -r s; do
  [ -n "$s" ] && files+=("$PWD/$s")
done <<< "$sels"
exec nvr "${files[@]}"
