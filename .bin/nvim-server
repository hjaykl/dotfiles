#!/usr/bin/env bash
# Launch nvim with a session-scoped --listen socket.
# Outside tmux, or if a live server is already bound to the session socket,
# launch detached without --listen.
set -e

if [ -z "$TMUX" ]; then
  exec nvim "$@"
fi

dir="${XDG_RUNTIME_DIR:-/tmp}/nvim"
mkdir -p "$dir"
sock="$dir/$(tmux display-message -p '#S').sock"

if nvim --server "$sock" --remote-expr '1' >/dev/null 2>&1; then
  echo "nvim-server: session socket already bound at $sock — launching detached" >&2
  exec nvim "$@"
fi

rm -f "$sock"
exec nvim --listen "$sock" "$@"
