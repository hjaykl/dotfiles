layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
                format_left   "{mode}{tabs}"
                format_center ""
                format_right  "{session}"
                format_space  ""
                format_hide_on_overlength "true"
                format_precedence "lrc"

                mode_normal        ""
                mode_tmux          "#[fg=#141415,bg=#f3be7c,bold] TMUX #[fg=#f3be7c,bg=#141415]"
                mode_scroll        "#[fg=#141415,bg=#aeaed1,bold] SCROLL #[fg=#aeaed1,bg=#141415]"
                mode_search        "#[fg=#141415,bg=#bb9dbd,bold] SEARCH #[fg=#bb9dbd,bg=#141415]"
                mode_rename_tab    "#[fg=#141415,bg=#f3be7c,bold] RENAME #[fg=#f3be7c,bg=#141415]"

                tab_normal              "#[fg=#606079] {index}:{name} "
                tab_normal_fullscreen   "#[fg=#606079] {index}:{name} 󰊓 "
                tab_normal_sync         "#[fg=#606079] {index}:{name} 󰓦 "
                tab_active              "#[fg=#141415,bg=#90a0b5,bold] {index}:{name} #[fg=#90a0b5,bg=#141415]"
                tab_active_fullscreen   "#[fg=#141415,bg=#90a0b5,bold] {index}:{name} 󰊓 #[fg=#90a0b5,bg=#141415]"
                tab_active_sync         "#[fg=#141415,bg=#90a0b5,bold] {index}:{name} 󰓦 #[fg=#90a0b5,bg=#141415]"
                tab_separator           ""

                session_name "#[fg=#606079] {name} "
            }
        }
        children
    }

    tab name="nvim" focus=true {
        pane command="nvim-server"
    }

    tab name="claude" {
        pane command="claude"
    }

    tab name="server" {
        pane
    }

    tab name="shell" {
        pane
    }
}
